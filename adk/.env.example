# Modelo LiteLLM (padrão: GitHub Copilot Chat API).
# Ex.: github_copilot/gpt-4 — ver https://docs.litellm.ai/docs/providers/github_copilot
ADK_LLM_MODEL=github_copilot/gpt-4

# Fallback — modelos alternativos (ordem de prioridade)
ADK_LLM_FALLBACK_MODEL_1=openrouter/meta-llama/llama-4-scout
ADK_LLM_FALLBACK_MODEL_2=openrouter/google/gemini-2.0-flash
OPENROUTER_API_KEY=

# Diretório de discovery de apps ADK.
# Produção (default): runners
# Desenvolvimento: agents/roles
ADK_AGENTS_DIR=runners

# Langfuse — observabilidade
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_ENABLED=true

# Alerta de consumo
DAILY_TOKEN_LIMIT=1000000
ALERT_WEBHOOK_URL=

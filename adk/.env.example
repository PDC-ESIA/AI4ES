# Modelo LiteLLM (padrão: GitHub Copilot Chat API).
# Ex.: github_copilot/gpt-4 — ver https://docs.litellm.ai/docs/providers/github_copilot
ADK_LLM_MODEL=github_copilot/gpt-4

# Opcional: integrações Google (outros fluxos / agentes).
GOOGLE_API_KEY=

# Opcional: se usar outro modelo LiteLLM que exija chave (ex. mistral/...).
# MISTRAL_API_KEY=

# Modelo LiteLLM (padrão: GitHub Copilot Chat API).
# Ex.: github_copilot/gpt-4 — ver https://docs.litellm.ai/docs/providers/github_copilot
ADK_LLM_MODEL=github_copilot/gpt-4

# Diretório de discovery de apps ADK.
# Produção (default): runners
# Desenvolvimento: agents/roles
ADK_AGENTS_DIR=runners

# ---------------------------------------------------------------------------
# Fallback – chaves dos provedores alternativos (usadas pelo llm_config.yaml)
# ---------------------------------------------------------------------------
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Langfuse – observabilidade de LLM (tokens, latência, custo)
# Quando definidas, o LiteLLM envia métricas automaticamente para o Langfuse.
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Limite diário de tokens para o script de alerta (scripts/check_usage.py)
DAILY_TOKEN_LIMIT=1000000
